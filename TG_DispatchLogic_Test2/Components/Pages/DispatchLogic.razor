@page "/dispatch-logic"
@rendermode InteractiveServer
@inject DispatchLogicSessionService Session
@inject AmrApiClient AmrApi
@implements IAsyncDisposable

<PageTitle>派車邏輯</PageTitle>

<div class="page-content dispatch-logic-page">
    <PageHeader Title="Buffer / 撚紗派車邏輯"
                Subtitle="@($"Modbus 料況 + TGI {AmrApi.BaseUrl} · Buffer/上料 CAKE-01~12 · 下料/清軸 CAKE-13~24 · 全場共用狀態")" />

    <div class="dispatch-fleet-note @(_fleetTableExpanded ? "is-expanded" : "")">
        <button type="button" class="dispatch-fleet-note-toggle" @onclick="ToggleFleetTable">
            <div class="dispatch-fleet-note-title">
                <span class="equip-badge equip-badge-call">車號對照</span>
                @if (_fleetTableExpanded)
                {
                    <span class="parking-cat-muted small">派車動作依下列車隊區分；未規劃者日後再補</span>
                }
                else
                {
                    <span class="parking-cat-muted small">
                        Cake @DispatchFleetCatalog.Assignments.Count(a => a.VehicleType == "Cake" && a.VehicleCodes.Count > 0) 組已規劃
                        · Bobbin @DispatchFleetCatalog.Assignments.Count(a => a.VehicleType == "Bobbin" && a.VehicleCodes.Count > 0) 組已規劃
                        · 共 @DispatchFleetCatalog.Assignments.Count 列
                    </span>
                }
            </div>
            <span class="dispatch-ref-chevron">@(_fleetTableExpanded ? "▲ 收合" : "▼ 展開")</span>
        </button>
        @if (_fleetTableExpanded)
        {
            <table class="parking-cat-table dispatch-fleet-table">
                <thead>
                    <tr>
                        <th>派車動作</th>
                        <th>車種</th>
                        <th>車號範圍</th>
                        <th>台數</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in DispatchFleetCatalog.Assignments)
                    {
                        <tr>
                            <td>@row.DispatchAction</td>
                            <td>
                                <span class="equip-badge @(row.VehicleType == "Cake" ? "equip-badge-call" : "equip-badge-info")">
                                    @row.VehicleType
                                </span>
                            </td>
                            <td class="mono">@row.VehicleRangeLabel</td>
                            <td class="mono">@(row.VehicleCodes.Count > 0 ? row.VehicleCodes.Count.ToString() : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="equip-sim-toolbar">
        <div class="equip-sim-conn">
            <label>Modbus IP</label>
            <DxTextBox @bind-Text="Session.ModbusHost" @bind-Text:after="OnSettingsChanged" CssClass="equip-sim-input" />
            <label>Port</label>
            <DxSpinEdit @bind-Value="Session.ModbusPort" @bind-Value:after="OnSettingsChanged" MinValue="1" MaxValue="65535" CssClass="equip-sim-spin" />
            <label>Unit ID</label>
            <DxSpinEdit @bind-Value="Session.UnitId" @bind-Value:after="OnSettingsChanged" MinValue="0" MaxValue="255" CssClass="equip-sim-spin" />
        </div>
        <div class="equip-sim-status">
            <span class="equip-live-dot @(Session.Snapshot?.Success == true ? "is-ok" : "is-err")"></span>
            @if (Session.Snapshot?.Success == true)
            {
                <span>Modbus · @Session.Snapshot.ElapsedMs ms · @Session.Snapshot.PolledAt.ToString("HH:mm:ss")</span>
            }
            else if (Session.ModbusBusy && Session.Snapshot is null)
            {
                <span>Modbus 連線中…</span>
            }
            else
            {
                <span class="text-danger">@(Session.Snapshot?.Error ?? "Modbus 尚未讀取")</span>
            }
            <span class="dispatch-amr-status @(Session.AmrError is null ? "ok" : "err")">
                @if (Session.AmrError is null && Session.LastAmrRefresh is not null)
                {
                    <text>TGI · @Session.LastAmrRefresh.Value.ToString("HH:mm:ss")</text>
                }
                else if (Session.AmrError is not null)
                {
                    <text>@Session.AmrError</text>
                }
            </span>
            <DxCheckBox @bind-Checked="Session.AutoRefresh" @bind-Checked:after="OnSettingsChanged">自動更新（Buffer 0.8 秒 · TGI 1.5 秒）</DxCheckBox>
            <DxButton Text="立即更新"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      CssClass="dispatch-refresh-now"
                      Click="RefreshNowAsync"
                      Enabled="@(!Session.ModbusBusy && !Session.TgiBusy)" />
        </div>
    </div>

    <div class="equip-tab-bar">
        <button type="button" class="equip-tab-btn @(Session.MainTab == "buffer" ? "active" : "")"
                @onclick='() => Session.SetMainTab("buffer")'>Buffer 區派Cake車</button>
        <button type="button" class="equip-tab-btn @(Session.MainTab == "twisting-load" ? "active" : "")"
                @onclick='() => Session.SetMainTab("twisting-load")'>撚紗上料派Cake車</button>
        <button type="button" class="equip-tab-btn @(Session.MainTab == "twisting-unload" ? "active" : "")"
                @onclick='() => Session.SetMainTab("twisting-unload")'>撚紗下料派Cake車</button>
        <button type="button" class="equip-tab-btn @(Session.MainTab == "twisting-unload-bobbin" ? "active" : "")"
                @onclick='() => Session.SetMainTab("twisting-unload-bobbin")'>撚紗下料派Bobbin車</button>
        <button type="button" class="equip-tab-btn @(Session.MainTab == "clearing-load" ? "active" : "")"
                @onclick='() => Session.SetMainTab("clearing-load")'>清軸上料派Cake車</button>
        <button type="button" class="equip-tab-btn @(Session.MainTab == "aoi-load" ? "active" : "")"
                @onclick='() => Session.SetMainTab("aoi-load")'>AOI上料派Bobbin車</button>
    </div>

    @if (Session.MainTab == "buffer")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.DispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.DispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetDispatchModeAuto">自動派車</button>
            @if (Session.DispatchMode == "manual")
            {
                <span class="api-test-hint">檢查 JSON 後按各組「派車」</span>
            }
            else
            {
                <span class="api-test-hint">符合配對條件時自動派車 · 每 @DispatchLogicSessionService.BufferAutoDispatchIntervalSeconds 秒最多派 1 組</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.ActiveInFlightCount"
                                    LogCount="Session.DispatchLogs.Count"
                                    OnReset="Session.ResetBufferDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            Buffer：作業面 12 Port 皆有料 · 停車點無車停靠 · Cake 車：idle、無任務、12 Port 全空 · 配對優先等待區（WP）車輛 · 派車後 Buffer 鎖定至任務完成
        </div>

        @if (Session.Snapshot is null)
        {
            <p class="api-test-hint">正在讀取 Modbus 資料…</p>
        }
        else if (!Session.Snapshot.Success)
        {
            <p class="text-danger">@(Session.Snapshot.Error ?? "Modbus 讀取失敗")</p>
        }
        else
        {
            <div class="dispatch-summary @(Session.AvailableBufferCount > 0 ? "has-ready" : "")">
                <strong>Buffer 可派車：@Session.AvailableBufferCount</strong>
                <span>· 可派 Cake 車：@(Session.CakeVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
                <span>· 配對：@(Session.Pairings?.Count ?? 0) 組</span>
                @if (Session.ActiveInFlightCount > 0)
                {
                    <span>· 任務中：@Session.ActiveInFlightCount</span>
                }
            </div>

            @if (Session.Pairings is { Count: > 0 })
            {
                <section class="dispatch-section">
                    <h3 class="dispatch-section-title">配對與派車（amr_mission）</h3>
                    <div class="dispatch-pair-grid">
                        @foreach (var pair in Session.Pairings)
                        {
                            <DispatchBufferPairCard Pair="pair"
                                                    DispatchMode="@Session.DispatchMode"
                                                    DispatchBusy="@Session.DispatchBusy"
                                                    OnDispatch="Session.DispatchPairManualAsync" />
                        }
                    </div>
                </section>
            }
            else if (Session.DispatchableBufferCount > 0 && Session.ActiveInFlightCount == 0)
            {
                <p class="api-test-hint">有 Buffer 可派車，但目前沒有可用的空閒 Cake 車可配對。</p>
            }
            else if (Session.DispatchableBufferCount == 0 && Session.ActiveInFlightCount == 0)
            {
                <p class="api-test-hint">目前無符合條件的 Buffer 或配對。</p>
            }

            <DispatchBufferInFlightPanel Tasks="Session.ActiveInFlightTasks" />
            <DispatchBufferLogPanel Logs="Session.DispatchLogs" />
        }

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Cake 車 Port 明細（CAKE-01 ~ CAKE-12）
                <span class="parking-cat-muted small">GET /v2/robots/status · 展開可看 12 Port</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss") · API 回報 @Session.TgiRobotReportCount 台
                </p>
            }
            else
            {
                <p class="api-test-hint small dispatch-tgi-hint">等待 TGI 連線…</p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.CakeVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.Snapshot?.Success == true && Session.BufferEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">Buffer 作業面明細</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.BufferEvaluations)
                    {
                        var meta = BufferParkingRegistry.Get(eval.StationId);
                        if (meta is null) continue;
                        var inFlight = Session.InFlightDispatches.FirstOrDefault(f =>
                            f.IsActive &&
                            f.ParkingPointId.Equals(eval.ParkingPointId, StringComparison.OrdinalIgnoreCase));
                        <DispatchBufferStationView Meta="meta"
                                                   Evaluation="eval"
                                                   InFlight="inFlight" />
                    }
                </div>
            </section>
        }
    }
    else if (Session.MainTab == "twisting-load")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.TwpDispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetTwpDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.TwpDispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetTwpDispatchModeAuto">自動派車</button>
            @if (Session.TwpDispatchMode == "manual")
            {
                <span class="api-test-hint">一組配對依序 POST 3 次 flow（每次 4 手臂任務）</span>
            }
            else
            {
                <span class="api-test-hint">叫車狀態 + 3 停車點可上料時自動派車 · 每 @DispatchLogicSessionService.TwpAutoDispatchIntervalSeconds 秒最多派 1 組（等同按派車鍵）</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.TwpActiveInFlightCount"
                                    LogCount="Session.TwpDispatchLogs.Count"
                                    OnReset="Session.ResetTwpDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            撚紗機：狀態=叫車、尾端 3 停車點 × 4 Cake Port 待上料 · 優先序：機台 → 左右走道（可同時派尾端組）→ 走道內尾端往前 · 後組須前組車輛實際開進 TWP 走道（fleet current_site）· 同機同側最多 @TwistingParkingRegistry.MaxConcurrentMissionsPerSide 車
        </div>

        @if (Session.Snapshot is null)
        {
            <p class="api-test-hint">正在讀取 Modbus 資料…</p>
        }
        else if (!Session.Snapshot.Success)
        {
            <p class="text-danger">@(Session.Snapshot.Error ?? "Modbus 讀取失敗")</p>
        }
        else
        {
            <div class="dispatch-summary @(Session.TwpAvailableMissionBlockCount > 0 ? "has-ready" : "")">
                <strong>可派組數：@Session.TwpAvailableMissionBlockCount</strong>
                <span>· 叫車中機側：@Session.TwpCallableSideCount</span>
                <span>· 可派 Cake 車：@(Session.TwpCakeVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
                <span>· 配對：@(Session.TwpPairings?.Count ?? 0) 組</span>
                @if (Session.TwpActiveInFlightCount > 0)
                {
                    <span>· 任務中：@Session.TwpActiveInFlightCount</span>
                }
            </div>

            @if (Session.TwpPairings is { Count: > 0 })
            {
                <section class="dispatch-section">
                    <h3 class="dispatch-section-title">配對與派車（amr_mission · actionid=3）</h3>
                    <div class="dispatch-pair-grid">
                        @foreach (var pair in Session.TwpPairings)
                        {
                            <DispatchTwistingLoadPairCard Pair="pair"
                                                          CanDispatch="@Session.GetTwpPairCanDispatch(pair)"
                                                          DispatchBlockReason="@Session.GetTwpPairBlockReason(pair)"
                                                          DispatchMode="@Session.TwpDispatchMode"
                                                          DispatchBusy="@Session.TwpDispatchBusy"
                                                          OnDispatch="Session.DispatchTwpPairManualAsync" />
                        }
                    </div>
                </section>
            }
            else if (Session.TwpCallableSideCount > 0 && Session.TwpActiveInFlightCount == 0)
            {
                <p class="api-test-hint">有撚紗機可派車，但目前沒有可用的滿載 Cake 車可配對。</p>
            }
            else if (Session.TwpCallableSideCount == 0 && Session.TwpActiveInFlightCount == 0)
            {
                <p class="api-test-hint">目前無叫車狀態且湊滿 3 停車點的撚紗機，或無可配對車輛。</p>
            }

            <DispatchTwistingLoadInFlightPanel Tasks="Session.TwpActiveInFlightTasks" />
            <DispatchBufferLogPanel Logs="Session.TwpDispatchLogs" />
        }

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Cake 車 Port 明細（上料用 · CAKE-01 ~ CAKE-12）
                <span class="parking-cat-muted small">需 12 Port 有 Cake 有絲</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss")
                </p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.TwpCakeVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.Snapshot?.Success == true && Session.TwpMachineEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">撚紗機作業明細</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.TwpMachineEvaluations)
                    {
                        var inFlights = Session.TwpInFlightDispatches
                            .Where(f => f.IsActive && f.MissionKey.Equals(eval.MissionKey, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                        <DispatchTwistingLoadMachineView Evaluation="eval" InFlights="inFlights" />
                    }
                </div>
            </section>
        }
    }
    else if (Session.MainTab == "twisting-unload")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.TwpUnloadDispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetTwpUnloadDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.TwpUnloadDispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetTwpUnloadDispatchModeAuto">自動派車</button>
            @if (Session.TwpUnloadDispatchMode == "manual")
            {
                <span class="api-test-hint">一組配對依序 POST 3 次 flow（每次 4 手臂任務）</span>
            }
            else
            {
                <span class="api-test-hint">請下料狀態 + 3 停車點可下料時自動派車 · 每 @DispatchLogicSessionService.TwpAutoDispatchIntervalSeconds 秒最多派 1 組（等同按派車鍵）</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.TwpUnloadActiveInFlightCount"
                                    LogCount="Session.TwpUnloadDispatchLogs.Count"
                                    OnReset="Session.ResetTwpUnloadDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            狀態=請下料、尾端3停車點×4 Cake Port 皆無絲(1)、空車 CAKE-13~24、actionid=1、3次flow
        </div>

        @if (Session.Snapshot is null)
        {
            <p class="api-test-hint">正在讀取 Modbus 資料…</p>
        }
        else if (!Session.Snapshot.Success)
        {
            <p class="text-danger">@(Session.Snapshot.Error ?? "Modbus 讀取失敗")</p>
        }
        else
        {
            <div class="dispatch-summary @(Session.TwpUnloadAvailableMissionBlockCount > 0 ? "has-ready" : "")">
                <strong>可派組數：@Session.TwpUnloadAvailableMissionBlockCount</strong>
                <span>· 請下料機側：@Session.TwpUnloadRequestSideCount</span>
                <span>· 可派 Cake 車：@(Session.TwpUnloadCakeVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
                <span>· 配對：@(Session.TwpUnloadPairings?.Count ?? 0) 組</span>
                @if (Session.TwpUnloadActiveInFlightCount > 0)
                {
                    <span>· 任務中：@Session.TwpUnloadActiveInFlightCount</span>
                }
            </div>

            @if (Session.TwpUnloadPairings is { Count: > 0 })
            {
                <section class="dispatch-section">
                    <h3 class="dispatch-section-title">配對與派車（amr_mission · actionid=1）</h3>
                    <div class="dispatch-pair-grid">
                        @foreach (var pair in Session.TwpUnloadPairings)
                        {
                            <DispatchTwistingLoadPairCard Pair="pair"
                                                          CanDispatch="@Session.GetTwpUnloadPairCanDispatch(pair)"
                                                          DispatchBlockReason="@Session.GetTwpUnloadPairBlockReason(pair)"
                                                          DispatchMode="@Session.TwpUnloadDispatchMode"
                                                          DispatchBusy="@Session.TwpUnloadDispatchBusy"
                                                          ActionId="1"
                                                          ActionDirection="撚紗機→車"
                                                          OnDispatch="Session.DispatchTwpUnloadPairManualAsync" />
                        }
                    </div>
                </section>
            }
            else if (Session.TwpUnloadRequestSideCount > 0 && Session.TwpUnloadActiveInFlightCount == 0)
            {
                <p class="api-test-hint">有撚紗機可派車，但目前沒有可用的空閒 Cake 車可配對。</p>
            }
            else if (Session.TwpUnloadRequestSideCount == 0 && Session.TwpUnloadActiveInFlightCount == 0)
            {
                <p class="api-test-hint">目前無請下料狀態且湊滿 3 停車點的撚紗機，或無可配對車輛。</p>
            }

            <DispatchTwistingLoadInFlightPanel Tasks="Session.TwpUnloadActiveInFlightTasks" />
            <DispatchBufferLogPanel Logs="Session.TwpUnloadDispatchLogs" />
        }

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Cake 車 Port 明細（下料用 · CAKE-13 ~ CAKE-24）
                <span class="parking-cat-muted small">需 12 Port 空車（無絲）</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss")
                </p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.TwpUnloadCakeVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.Snapshot?.Success == true && Session.TwpUnloadMachineEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">撚紗機作業明細</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.TwpUnloadMachineEvaluations)
                    {
                        var inFlights = Session.TwpUnloadInFlightDispatches
                            .Where(f => f.IsActive && f.MissionKey.Equals(eval.MissionKey, StringComparison.OrdinalIgnoreCase))
                            .ToList();
                        <DispatchTwistingLoadMachineView Evaluation="eval" InFlights="inFlights" ForUnload="true" />
                    }
                </div>
            </section>
        }
    }
    else if (Session.MainTab == "twisting-unload-bobbin")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.TwpUnloadBobbinDispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetTwpUnloadBobbinDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.TwpUnloadBobbinDispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetTwpUnloadBobbinDispatchModeAuto">自動派車</button>
            @if (Session.TwpUnloadBobbinDispatchMode == "manual")
            {
                <span class="api-test-hint">一組配對依序 POST 6 次 flow（跨側殘餘亦 6 次：A3+B3；每次 4 手臂 · value_amr 1~24）</span>
            }
            else
            {
                <span class="api-test-hint">請下料 + 6 停車點可下 Bobbin 時自動派車 · 每 @DispatchLogicSessionService.TwpAutoDispatchIntervalSeconds 秒最多派 1 組</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.TwpUnloadBobbinActiveInFlightCount"
                                    LogCount="Session.TwpUnloadBobbinDispatchLogs.Count"
                                    OnReset="Session.ResetTwpUnloadBobbinDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            狀態=請下料、尾端6停車點×4 Bobbin Port 皆有絲(2)、空車 BOBBIN-01~08、actionid=1、artifact=bobbin_mission；
            殘餘 A3+B3 跨側為第 7 趟（兩邊 lane 都綠燈才派）
        </div>

        @if (Session.Snapshot is null)
        {
            <p class="api-test-hint">正在讀取 Modbus 資料…</p>
        }
        else if (!Session.Snapshot.Success)
        {
            <p class="text-danger">@(Session.Snapshot.Error ?? "Modbus 讀取失敗")</p>
        }
        else
        {
            <div class="dispatch-summary @(Session.TwpUnloadBobbinAvailableMissionBlockCount > 0 ? "has-ready" : "")">
                <strong>可派組數：@Session.TwpUnloadBobbinAvailableMissionBlockCount</strong>
                <span>· 請下料機側：@Session.TwpUnloadBobbinRequestSideCount</span>
                <span>· 可派 Bobbin 車：@(Session.TwpUnloadBobbinVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
                <span>· 配對：@(Session.TwpUnloadBobbinPairings?.Count ?? 0) 組</span>
                @if (Session.TwpUnloadBobbinActiveInFlightCount > 0)
                {
                    <span>· 任務中：@Session.TwpUnloadBobbinActiveInFlightCount</span>
                }
            </div>

            @if (Session.TwpUnloadBobbinPairings is { Count: > 0 })
            {
                <section class="dispatch-section">
                    <h3 class="dispatch-section-title">配對與派車（amr_mission · actionid=1 · bobbin_mission）</h3>
                    <div class="dispatch-pair-grid">
                        @foreach (var pair in Session.TwpUnloadBobbinPairings)
                        {
                            <DispatchTwistingLoadPairCard Pair="pair"
                                                          CanDispatch="@Session.GetTwpUnloadBobbinPairCanDispatch(pair)"
                                                          DispatchBlockReason="@Session.GetTwpUnloadBobbinPairBlockReason(pair)"
                                                          DispatchMode="@Session.TwpUnloadBobbinDispatchMode"
                                                          DispatchBusy="@Session.TwpUnloadBobbinDispatchBusy"
                                                          ActionId="1"
                                                          ActionDirection="撚紗機→Bobbin車"
                                                          OnDispatch="Session.DispatchTwpUnloadBobbinPairManualAsync" />
                        }
                    </div>
                </section>
            }
            else if (Session.TwpUnloadBobbinRequestSideCount > 0 && Session.TwpUnloadBobbinActiveInFlightCount == 0)
            {
                <p class="api-test-hint">有撚紗機可派車，但目前沒有可用的空閒 Bobbin 車可配對。</p>
            }
            else if (Session.TwpUnloadBobbinRequestSideCount == 0 && Session.TwpUnloadBobbinActiveInFlightCount == 0)
            {
                <p class="api-test-hint">目前無請下料且湊滿 6 停車點（或跨側殘餘）的撚紗機，或無可配對車輛。</p>
            }

            <DispatchTwistingLoadInFlightPanel Tasks="Session.TwpUnloadBobbinActiveInFlightTasks" />
            <DispatchBufferLogPanel Logs="Session.TwpUnloadBobbinDispatchLogs" />
        }

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Bobbin 車 Port 明細（下料用 · BOBBIN-01 ~ BOBBIN-08）
                <span class="parking-cat-muted small">需 24 Port 全空</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss")
                </p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.TwpUnloadBobbinVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.Snapshot?.Success == true && Session.TwpUnloadBobbinMachineEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">撚紗機 Bobbin 作業明細</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.TwpUnloadBobbinMachineEvaluations)
                    {
                        var inFlights = Session.TwpUnloadBobbinInFlightDispatches
                            .Where(f => f.IsActive &&
                                        (f.MissionKey.Equals(eval.MissionKey, StringComparison.OrdinalIgnoreCase) ||
                                         (f.IsCrossSide && f.MachineId == eval.MachineId)))
                            .ToList();
                        <DispatchTwistingLoadMachineView Evaluation="eval" InFlights="inFlights" ForBobbinUnload="true" />
                    }
                </div>
            </section>
        }
    }
    else if (Session.MainTab == "clearing-load")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.ClrDispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetClrDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.ClrDispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetClrDispatchModeAuto">自動派車</button>
            @if (Session.ClrDispatchMode == "manual")
            {
                <span class="api-test-hint">檢查 JSON 後按各組「派車」</span>
            }
            else
            {
                <span class="api-test-hint">符合配對條件時自動派車 · 每 @DispatchLogicSessionService.TwpAutoDispatchIntervalSeconds 秒最多派 1 組</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.ClrActiveInFlightCount"
                                    LogCount="Session.ClrDispatchLogs.Count"
                                    OnReset="Session.ResetClrDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            清軸：CLR001~005 停車點空 + 單行道可達（外側無車）· 忽略 Modbus · Cake 車 CAKE-13~24：idle、無任務、12 Port 皆無絲(1) · 一次 12 Port actionid=2 · 派車後鎖定至任務完成
        </div>

        <div class="dispatch-summary @(Session.ClrAvailableStationCount > 0 ? "has-ready" : "")">
            <strong>清軸可派：@Session.ClrAvailableStationCount</strong>
            <span>· 可派 Cake 車：@(Session.ClrCakeVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
            <span>· 配對：@(Session.ClrPairings?.Count ?? 0) 組</span>
            @if (Session.ClrActiveInFlightCount > 0)
            {
                <span>· 任務中：@Session.ClrActiveInFlightCount</span>
            }
        </div>

        @if (Session.ClrPairings is { Count: > 0 })
        {
            <section class="dispatch-section">
                <h3 class="dispatch-section-title">配對與派車（amr_mission）</h3>
                <div class="dispatch-pair-grid">
                    @foreach (var pair in Session.ClrPairings)
                    {
                        <DispatchClearingLoadPairCard Pair="pair"
                                                      DispatchMode="@Session.ClrDispatchMode"
                                                      DispatchBusy="@Session.ClrDispatchBusy"
                                                      OnDispatch="Session.DispatchClrPairManualAsync" />
                    }
                </div>
            </section>
        }
        else if (Session.ClrDispatchableStationCount > 0 && Session.ClrActiveInFlightCount == 0)
        {
            <p class="api-test-hint">有清軸站可派車，但目前沒有可用的無絲 Cake 車可配對。</p>
        }
        else if (Session.ClrDispatchableStationCount == 0 && Session.ClrActiveInFlightCount == 0)
        {
            <p class="api-test-hint">目前無符合條件的清軸站或配對。</p>
        }

        <DispatchClearingLoadInFlightPanel Tasks="Session.ClrActiveInFlightTasks" />
        <DispatchBufferLogPanel Logs="Session.ClrDispatchLogs" />

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Cake 車 Port 明細（CAKE-13 ~ CAKE-24）
                <span class="parking-cat-muted small">需 12 Port 皆為無絲(1) · GET /v2/robots/status</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss") · API 回報 @Session.TgiRobotReportCount 台
                </p>
            }
            else
            {
                <p class="api-test-hint small dispatch-tgi-hint">等待 TGI 連線…</p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.ClrCakeVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.ClrStationEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">清軸站明細（CLR001 最內 → CLR005 最外）</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.ClrStationEvaluations)
                    {
                        var inFlight = Session.ClrInFlightDispatches.FirstOrDefault(f =>
                            f.IsActive &&
                            f.ParkingPointId.Equals(eval.ParkingPointId, StringComparison.OrdinalIgnoreCase));
                        <DispatchClearingLoadStationView Evaluation="eval" InFlight="inFlight" />
                    }
                </div>
            </section>
        }
    }
    else if (Session.MainTab == "aoi-load")
    {
        <div class="dispatch-mode-bar">
            <span class="equip-panel-hint mb-0">派車模式</span>
            <button type="button" class="equip-tab-btn small @(Session.AoiDispatchMode == "manual" ? "active" : "")"
                    @onclick="Session.SetAoiDispatchModeManual">手動（先預覽 JSON）</button>
            <button type="button" class="equip-tab-btn small @(Session.AoiDispatchMode == "auto" ? "active" : "")"
                    @onclick="Session.SetAoiDispatchModeAuto">自動派車</button>
            @if (Session.AoiDispatchMode == "manual")
            {
                <span class="api-test-hint">檢查 JSON 後按各組「派車」（單次 POST · 24 Port）</span>
            }
            else
            {
                <span class="api-test-hint">符合配對條件時自動派車 · 每 @DispatchLogicSessionService.TwpAutoDispatchIntervalSeconds 秒最多派 1 組</span>
            }
            <DispatchStatusResetBar InFlightCount="Session.AoiActiveInFlightCount"
                                    LogCount="Session.AoiDispatchLogs.Count"
                                    OnReset="Session.ResetAoiDispatchStateAsync" />
        </div>

        <div class="equip-panel-hint">
            AOI：PKP001~002 未鎖即可（不擋停車點有人）· 忽略 Modbus · 兩站可同時派 · Bobbin 車 BOBBIN-01~08：idle、無任務、24 Port 皆有絲(2) · 多台可派時優先率先達成條件者 · actionid=2 · bobbin_mission · 派車後鎖定至任務完成
        </div>

        <div class="dispatch-summary @(Session.AoiAvailableStationCount > 0 ? "has-ready" : "")">
            <strong>AOI 可派：@Session.AoiAvailableStationCount</strong>
            <span>· 可派 Bobbin 車：@(Session.AoiBobbinVehicles.Count(v => v.IsEligible && !Session.IsAmrBusy(v.AmrCode)))</span>
            <span>· 配對：@(Session.AoiPairings?.Count ?? 0) 組</span>
            @if (Session.AoiActiveInFlightCount > 0)
            {
                <span>· 任務中：@Session.AoiActiveInFlightCount</span>
            }
        </div>

        @if (Session.AoiPairings is { Count: > 0 })
        {
            <section class="dispatch-section">
                <h3 class="dispatch-section-title">配對與派車（amr_mission · actionid=2 · bobbin_mission）</h3>
                <div class="dispatch-pair-grid">
                    @foreach (var pair in Session.AoiPairings)
                    {
                        <DispatchAoiLoadPairCard Pair="pair"
                                                 DispatchMode="@Session.AoiDispatchMode"
                                                 DispatchBusy="@Session.AoiDispatchBusy"
                                                 OnDispatch="Session.DispatchAoiPairManualAsync" />
                    }
                </div>
            </section>
        }
        else if (Session.AoiDispatchableStationCount > 0 && Session.AoiActiveInFlightCount == 0)
        {
            <p class="api-test-hint">有 AOI 站可派車，但目前沒有可用的滿載 Bobbin 車可配對。</p>
        }
        else if (Session.AoiDispatchableStationCount == 0 && Session.AoiActiveInFlightCount == 0)
        {
            <p class="api-test-hint">目前無符合條件的 AOI 站或配對。</p>
        }

        <DispatchAoiLoadInFlightPanel Tasks="Session.AoiActiveInFlightTasks" />
        <DispatchBufferLogPanel Logs="Session.AoiDispatchLogs" />

        <section class="dispatch-section dispatch-detail-section">
            <h3 class="dispatch-section-title">
                Bobbin 車 Port 明細（BOBBIN-01 ~ BOBBIN-08）
                <span class="parking-cat-muted small">需 24 Port 皆為有絲(2) · GET /v2/robots/status</span>
            </h3>
            @if (Session.AmrError is not null)
            {
                <p class="text-danger small dispatch-tgi-hint">@Session.AmrError</p>
            }
            else if (Session.LastAmrRefresh is not null)
            {
                <p class="api-test-hint small dispatch-tgi-hint">
                    TGI 最後更新 @Session.LastAmrRefresh.Value.ToString("HH:mm:ss") · API 回報 @Session.TgiRobotReportCount 台
                </p>
            }
            <div class="dispatch-buffer-grid">
                @foreach (var v in Session.AoiBobbinVehicles)
                {
                    <DispatchCakeVehicleView Vehicle="v" />
                }
            </div>
        </section>

        @if (Session.AoiStationEvaluations is { Count: > 0 })
        {
            <section class="dispatch-section dispatch-detail-section">
                <h3 class="dispatch-section-title">AOI 包裝站明細（PKP001 / PKP002）</h3>
                <div class="dispatch-buffer-grid">
                    @foreach (var eval in Session.AoiStationEvaluations)
                    {
                        var inFlight = Session.AoiInFlightDispatches.FirstOrDefault(f =>
                            f.IsActive &&
                            f.ParkingPointId.Equals(eval.ParkingPointId, StringComparison.OrdinalIgnoreCase));
                        <DispatchAoiLoadStationView Evaluation="eval" InFlight="inFlight" />
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    bool _fleetTableExpanded;

    protected override void OnInitialized()
    {
        Session.StateChanged += OnSessionStateChanged;
        Session.EnsurePollingStarted();
    }

    void ToggleFleetTable() => _fleetTableExpanded = !_fleetTableExpanded;

    void OnSessionStateChanged() => InvokeAsync(StateHasChanged);

    void OnSettingsChanged() => Session.NotifySettingsChanged();

    Task RefreshNowAsync() => Session.RefreshNowAsync();

    public ValueTask DisposeAsync()
    {
        Session.StateChanged -= OnSessionStateChanged;
        return ValueTask.CompletedTask;
    }
}
